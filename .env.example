# =============================================
# VILLAGE OFFICE SYSTEM — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# --- SERVER ---
PORT=5000
NODE_ENV=development

# --- DATABASE (Required) ---
# Paste your MongoDB Atlas connection string here
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/village-office?retryWrites=true&w=majority

# --- JWT AUTH ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- GOOGLE MAPS (Optional — enable when ready) ---
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=

# --- TWILIO SMS (Optional — enable when ready) ---
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- WHATSAPP (Optional — Twilio WhatsApp Sandbox) ---
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- FILE UPLOADS ---
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
